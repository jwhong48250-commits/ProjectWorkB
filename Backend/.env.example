# =================================================================
# 시스템 기본
# SECRET_KEY: python -c "import secrets; print(secrets.token_urlsafe(64))"
# RESET_DB_ON_STARTUP: True면 DEBUG=True일 때만 서버 기동 시 DB 초기화(주의)
# =================================================================
ENV=dev
DEBUG=True
RESET_DB_ON_STARTUP=False
# (선택) docker-compose 등에서만 사용. FastAPI Settings 필드는 아님.
# TZ=Asia/Seoul

# MySQL (로컬 예시)
DATABASE_URL=mysql+pymysql://root:1234@localhost:3307/meeting_assistant

# Railway MySQL (배포 시)
# DATABASE_URL=mysql://user:pass@host:port/railway

# MongoDB
MONGODB_URL=mongodb://root:1234@localhost:27017/meeting_assistant?authSource=admin

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001

# Redis (비밀번호 없음)
REDIS_URL=redis://localhost:6379
# Redis (비밀번호 있음)
# REDIS_URL=redis://:password@host:6379

SECRET_KEY=여기에_직접_생성한_값_입력
ALGORITHM=HS256

# =================================================================
# AI
# =================================================================
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
TAVILY_API_KEY=

# =================================================================
# Slack OAuth — https://api.slack.com/apps
# nginx/HTTPS 로컬: https://localhost/api/v1/integrations/slack/callback
# =================================================================
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:8000/api/v1/integrations/slack/callback

# =================================================================
# Jira OAuth
# =================================================================
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
JIRA_REDIRECT_URI=http://localhost:8000/api/v1/integrations/jira/callback

# =================================================================
# Google — Calendar 연동 + 로그인 OAuth
# https://console.cloud.google.com
# =================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/integrations/google/callback
GOOGLE_LOGIN_REDIRECT_URI=http://localhost:8000/api/v1/users/oauth/google/callback

# =================================================================
# Kakao — 로그인 등 (카카오 개발자 콘솔)
# =================================================================
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_LOGIN_REDIRECT_URI=http://localhost:8000/api/v1/users/oauth/kakao/callback

# =================================================================
# 프론트엔드 (OAuth 리다이렉트·비밀번호 재설정 링크 등)
# 로컬: http://localhost:5173  |  배포: https://your-frontend.example.com
# =================================================================
FRONTEND_URL=http://localhost:5173

# =================================================================
# 이메일 (SMTP) — 관리자 가입 안내·비밀번호 재설정 등
# =================================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Workb
SMTP_USE_TLS=True
ADMIN_SIGNUP_EMAIL_ENABLED=True
PASSWORD_RESET_TOKEN_MINUTES=30

# =================================================================
# AWS S3 — IAM: s3:PutObject, s3:GetObject
# =================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=
AWS_S3_PRESIGNED_EXPIRES=3600

# =================================================================
# 백그라운드 알림 잡 (기본 켜짐)
# =================================================================
NOTIFICATION_JOBS_ENABLED=True
NOTIFICATION_JOB_INTERVAL_SEC=60

# =================================================================
# 개발·QA — WAV 업로드 회의 시뮬레이션 (/meetings/.../simulate). 운영은 False
# =================================================================
WAV_SIM_ENABLED=False

# =================================================================
# Railway 등 배포 시 체크리스트
# - DATABASE_URL → 플랫폼에서 주입
# - GOOGLE_REDIRECT_URI / SLACK_REDIRECT_URI / JIRA_REDIRECT_URI → https 공개 URL
# - GOOGLE_LOGIN_REDIRECT_URI / KAKAO_LOGIN_REDIRECT_URI → 백엔드 콜백 공개 URL
# - FRONTEND_URL → 실제 프론트 origin
# - DEBUG=False, ENV=production, RESET_DB_ON_STARTUP=False
# =================================================================
