# ── API (필수) ─────────────────────────────────────────────────────────────
# 백엔드 origin. `/api/v1` 포함 여부 모두 허용(클라이언트에서 origin만 사용).
# 레거시 별칭: VITE_API_URL (가능하면 VITE_API_BASE_URL만 사용)
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ── 실시간 STT / 라이브 (선택) ─────────────────────────────────────────────
# 미설정 시 코드 기본값: WS ws://localhost:8888, ASR http://localhost:8888
# 원격 ASR·게이트웨이를 쓰는 환경에서만 오버라이드
# VITE_WS_BASE=ws://localhost:8888
# VITE_ASR_SERVER=http://localhost:8888
